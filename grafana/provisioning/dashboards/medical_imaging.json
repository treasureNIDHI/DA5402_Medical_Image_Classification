      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Predictions",
      "type": "stat",
      "targets": [{ "expr": "sum(http_requests_total{endpoint=\"/predict\"})", "legendFormat": "Predictions" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 0.2}] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Avg Inference Latency",
      "type": "stat",
      "targets": [{ "expr": "rate(http_request_duration_seconds_sum{endpoint=\"/predict\"}[5m]) / rate(http_request_duration_seconds_count{endpoint=\"/predict\"}[5m])", "legendFormat": "Latency" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "thresholds": { "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.9}, {"color": "green", "value": 0.99}] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Success Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_requests_total{endpoint=\"/predict\",status_code=\"200\"}[5m])) / sum(rate(http_requests_total{endpoint=\"/predict\"}[5m]))", "legendFormat": "Success Rate" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_requests_total{endpoint=\"/predict\"}[1m])", "legendFormat": "/predict" },
        { "expr": "rate(http_requests_total{endpoint=\"/health\"}[1m])", "legendFormat": "/health" },
        { "expr": "rate(http_requests_total{endpoint=\"/metrics\"}[1m])", "legendFormat": "/metrics" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Inference Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[5m]))", "legendFormat": "p99" }
      ]
    }
